# Jira (Server/Data Center)
JIRA_URL=https://jira.bank.com.pl
JIRA_PAT=your-personal-access-token

# Confluence (Server/Data Center)
CONFLUENCE_URL=https://confluence.bank.com.pl
CONFLUENCE_PAT=your-personal-access-token

# Grafana
GRAFANA_URL=http://grafana.internal:3000
GRAFANA_TOKEN=glsa_xxxxxxxxxxxx

# Bitbucket (Server)
BITBUCKET_URL=https://bitbucket.bank.com.pl
BITBUCKET_PAT=your-personal-access-token

# Ollama
OLLAMA_URL=http://localhost:11434

# Server
MCP_SERVER_PORT=8000
MCP_LOG_LEVEL=INFO
MCP_API_KEY=your-mcp-api-key-for-clients

# TLS CA bundle (internal PKI)
TLS_CA_BUNDLE=/etc/pki/tls/certs/ca-bundle.crt

# HTTP timeouts
JIRA_TIMEOUT=30
CONFLUENCE_TIMEOUT=30
GRAFANA_TIMEOUT=60
BITBUCKET_TIMEOUT=30
OLLAMA_TIMEOUT=30
